# Public deployment values. `npm run deploy:contract` fills these after publish.
SUI_PACKAGE_ID=
SUI_OPERATOR_CAP_ID=

# Optional Sui provider override. Public Mysten endpoints are the safe default.
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_GRPC_URL=https://fullnode.testnet.sui.io:443
# Tatum JSON-RPC endpoint, if you have a key:
# SUI_RPC_URL=https://sui-testnet.gateway.tatum.io
# Tatum native gRPC endpoint, if you have a key and verify object reads:
# SUI_GRPC_URL=https://sui-testnet-grpc.gateway.tatum.io
TATUM_API_KEY=

# Optional runtime service signer for backend-written contract transactions.
# Do not put a personal deploy key here.
SUI_OPERATOR_SECRET_KEY=

# Required for native Sui x402. Use a funded service key for sponsorship.
X402_SUI_FACILITATOR_SECRET_KEY=

# For npm run agent:buy
AGENT_SUI_SECRET_KEY=
