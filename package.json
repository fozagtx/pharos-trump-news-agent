{
  "name": "walrus-exchange",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "tsx watch src/server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node dist/server/index.js",
    "import:sui-key": "zsh scripts/import-sui-key.sh",
    "set:runtime-key": "zsh scripts/set-runtime-key.sh",
    "deploy:contract": "node scripts/deploy-contract.mjs",
    "agent:buy": "tsx src/agent/buy.ts",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@heroicons/react": "^2.2.0",
    "@mysten/dapp-kit-react": "^2.0.3",
    "@mysten/seal": "^1.1.3",
    "@mysten/sui": "^2.17.0",
    "@protobuf-ts/grpc-transport": "^2.11.1",
    "@tentaclepay/sui-x402": "^2.1.4",
    "@x402/core": "^2.12.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  }
}
