{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo/server.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["src/server/**/*.ts", "src/shared/**/*.ts", "src/agent/**/*.ts"]
}
